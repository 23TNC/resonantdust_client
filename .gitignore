# Godot editor/cache data
.import/
.godot/
*.import

# UID files
*.uid

# Android export build
/android/

# Build/export output directories
/build/
bin/
dist/
/spacetime/server/spacetimedb/target/
/spacetime/config
/spacetime/data

# spacetimedb data
/spacetime-data/*
/spacetime-keys/*

/pixijs/src/data
# Exported games
*.pck
*.apk
*.aab
*.exe
*.x86_64
*.arm64
*.ipa

# OS junk
.DS_Store
Thumbs.db

# Rust build artifacts
/target/
# wasm build dir (cargo target for the wasm wrapper) + wasm-pack output — both
# regenerable from core/ + wasm/ via `bin/client wasm`; never commit them.
/target-wasm/
/pkg/
**/*.rs.bk

# Bind-mount target for the shared workspace (compose mounts the main repo's
# `shared/` here at build time). Never real source — never commit it, so a stray
# host dir can't shadow the actual shared crates.
/shared/

# Cargo
Cargo.lock

# SpaceTimeDB local state
.spacetimedb/
spacetimedb.db

# Environment / secrets
.env
.env.*

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# npm
pixijs/node_modules/*